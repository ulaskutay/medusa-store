# Sunucu: apps/storefront/.env.local olarak kopyalayın
# Region admin'de yoksa middleware /dk gibi mevcut ülkeye yönlendirir (tr yoksa tr kullanmayın)

MEDUSA_BACKEND_URL=http://127.0.0.1:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_your_server_key_here
# SSL sonrası HTTPS domain kullanın (ör. https://shop.senindomain.com)
NEXT_PUBLIC_BASE_URL=https://shop.senindomain.com
# Türkiye mağazası için: tr (Medusa admin'de Türkiye bölgesi + TRY olmalı)
NEXT_PUBLIC_DEFAULT_REGION=tr
REVALIDATE_SECRET=change-me
NEXT_PUBLIC_SITE_NAME=Medusa Store
NEXT_PUBLIC_SITE_DESCRIPTION=Medusa B2C Storefront
